{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "work-item.schema.json",
  "type": "object",
  "required": ["id", "title", "status", "owner_scope", "affected_scopes", "depends_on", "acceptance_criteria", "created", "updated"],
  "properties": {
    "id": {"type": "string", "pattern": "^[0-9]{3,}$"},
    "title": {"type": "string", "minLength": 1},
    "status": {"enum": ["active", "blocked", "deferred", "completed"]},
    "owner_scope": {"type": "string", "minLength": 1},
    "affected_scopes": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "depends_on": {"type": "array", "items": {"type": "string", "pattern": "^[0-9]{3,}$"}, "uniqueItems": true},
    "preflight": {
      "type": "object",
      "required": ["created_before_work_started", "created_at", "note"],
      "properties": {
        "created_before_work_started": {"const": true},
        "created_at": {"type": "string", "format": "date-time"},
        "note": {"type": "string", "minLength": 1}
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "text", "state", "evidence"],
        "properties": {
          "id": {"type": "string"},
          "text": {"type": "string"},
          "state": {"enum": ["pending", "satisfied", "waived"]},
          "evidence": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "created": {"type": "string", "format": "date"},
    "updated": {"type": "string", "format": "date"}
  }
}

